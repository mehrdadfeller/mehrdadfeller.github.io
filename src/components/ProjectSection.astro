---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
}

const { project, index } = Astro.props;
const { data } = project;
const { Content } = await render(project);
const reversed = index % 2 === 1;

function toYoutubeEmbed(url: string) {
  const u = new URL(url);
  const id = u.hostname.includes('youtu.be') ? u.pathname.slice(1) : u.searchParams.get('v');
  return id ? `https://www.youtube.com/embed/${id}` : url;
}

const media = [
  ...data.images.map((src) => ({ type: 'image' as const, src })),
  ...(data.video ? [{ type: 'video' as const, src: toYoutubeEmbed(data.video) }] : []),
];
const multiple = media.length > 1;
---

<article class:list={['project', { 'project--reversed': reversed }]}>
  {media.length > 0 && (
    <div class="project__media">
      <div class="carousel" data-carousel>
        <div class="carousel__viewport">
          <ul class="carousel__track">
            {media.map((item, i) => (
              <li class="carousel__slide" aria-hidden={i === 0 ? 'false' : 'true'}>
                {item.type === 'image' ? (
                  <img src={item.src} alt={`${data.title} — image ${i + 1}`} loading="lazy" />
                ) : (
                  <div class="carousel__video">
                    <iframe
                      src={item.src}
                      title={`${data.title} — video`}
                      loading="lazy"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                    ></iframe>
                  </div>
                )}
              </li>
            ))}
          </ul>
        </div>

        {multiple && (
          <>
            <button class="carousel__btn carousel__btn--prev" data-dir="-1" aria-label="Previous slide">
              <span aria-hidden="true">‹</span>
            </button>
            <button class="carousel__btn carousel__btn--next" data-dir="1" aria-label="Next slide">
              <span aria-hidden="true">›</span>
            </button>
            <div class="carousel__dots">
              {media.map((_, i) => (
                <button
                  class="carousel__dot"
                  data-index={i}
                  aria-label={`Go to slide ${i + 1}`}
                  aria-selected={i === 0 ? 'true' : 'false'}
                ></button>
              ))}
            </div>
          </>
        )}
      </div>
    </div>
  )}

  <div class="project__body">
    <p class="eyebrow">{data.role} · {data.period}</p>
    <h3>{data.title}</h3>
    <p class="lead project__summary">{data.summary}</p>

    <div class="project__prose">
      <Content />
    </div>

    {data.tags.length > 0 && (
      <ul class="project__tags">
        {data.tags.map((t) => <li class="tag">{t}</li>)}
      </ul>
    )}

    {(data.links.live || data.links.repo || data.links.demo) && (
      <div class="project__links">
        {data.links.live && <a href={data.links.live} class="button">Visit site →</a>}
        {data.links.repo && <a href={data.links.repo} class="button">Source →</a>}
        {data.links.demo && <a href={data.links.demo} class="button">Demo →</a>}
      </div>
    )}
  </div>
</article>

<style>
  .project {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }
  .project + .project {
    border-top: 1px solid var(--hairline);
  }
  @media (min-width: 800px) {
    .project {
      grid-template-columns: 5fr 6fr;
    }
    .project--reversed .project__media {
      order: 2;
    }
  }
  .project__summary {
    margin-block: 0.75rem 1.25rem;
  }
  .project__prose {
    color: var(--ink-soft);
    max-width: var(--measure);
  }
  .project__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
  }
  .project__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  /* ---- Carousel ---- */
  .carousel {
    position: relative;
  }
  .carousel__viewport {
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--hairline);
    background: var(--surface);
  }
  .carousel__track {
    display: flex;
    margin: 0;
    padding: 0;
    list-style: none;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .carousel__slide {
    min-width: 100%;
  }
  .carousel__slide img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
  }
  .carousel__video {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2;
  }
  .carousel__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.6rem;
    height: 2.6rem;
    display: grid;
    place-items: center;
    font-size: 1.6rem;
    line-height: 1;
    color: var(--ink);
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .carousel__btn:hover {
    background: var(--accent);
    color: #fff;
  }
  .carousel__btn--prev {
    left: 0.75rem;
  }
  .carousel__btn--next {
    right: 0.75rem;
  }
  .carousel__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.9rem;
  }
  .carousel__dot {
    width: 0.55rem;
    height: 0.55rem;
    padding: 0;
    border-radius: 999px;
    border: none;
    background: var(--hairline);
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .carousel__dot[aria-selected='true'] {
    background: var(--accent);
    transform: scale(1.25);
  }
</style>

<script>
  function initCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>('.carousel__track');
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.carousel__slide'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('.carousel__dot'));
    if (!track || slides.length < 2) return;
    let index = 0;

    const update = () => {
      track.style.transform = `translateX(-${index * 100}%)`;
      slides.forEach((s, i) => s.setAttribute('aria-hidden', i === index ? 'false' : 'true'));
      dots.forEach((d, i) => d.setAttribute('aria-selected', i === index ? 'true' : 'false'));
    };

    root.querySelectorAll<HTMLElement>('[data-dir]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dir = Number(btn.dataset.dir);
        index = (index + dir + slides.length) % slides.length;
        update();
      });
    });
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        index = Number(dot.dataset.index);
        update();
      });
    });
    update();
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>
