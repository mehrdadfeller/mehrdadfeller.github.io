---
import { getCollection } from 'astro:content';

const talks = (await getCollection('talks')).sort((a, b) => b.data.year - a.data.year);
---

<section id="talks" class="section">
  <div class="container">
    <p class="eyebrow">Academic Work</p>
    <h2>Talks &amp; Video</h2>

    <ul class="talks">
      {talks.map((talk) => (
        <li class="talk">
          <a class="talk__link" href={talk.data.videoUrl} target="_blank" rel="noopener">
            <div class="talk__thumb">
              {talk.data.thumbnail ? (
                <img src={talk.data.thumbnail} alt={`${talk.data.title} thumbnail`} loading="lazy" />
              ) : (
                <span class="talk__play" aria-hidden="true">▶</span>
              )}
            </div>
            <div class="talk__body">
              <p class="talk__event">{talk.data.event} · {talk.data.year}</p>
              <h3 class="talk__title">{talk.data.title}</h3>
              {talk.data.description && <p class="talk__desc">{talk.data.description}</p>}
              <span class="talk__cta">Watch →</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .talks {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2rem);
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
  }
  .talk__link {
    display: block;
    height: 100%;
    color: inherit;
    border: 1px solid var(--hairline);
    border-radius: 12px;
    overflow: hidden;
    background: var(--surface);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .talk__link:hover {
    text-decoration: none;
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .talk__thumb {
    aspect-ratio: 16 / 9;
    background: var(--accent-soft);
    display: grid;
    place-items: center;
  }
  .talk__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .talk__play {
    font-size: 2rem;
    color: var(--accent);
  }
  .talk__body {
    padding: 1.25rem;
  }
  .talk__event {
    font-size: var(--step--1);
    color: var(--muted);
    margin: 0 0 0.3rem;
  }
  .talk__title {
    font-size: var(--step-1);
    margin-bottom: 0.5rem;
  }
  .talk__desc {
    color: var(--ink-soft);
    font-size: var(--step--1);
  }
  .talk__cta {
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--accent);
  }
</style>
