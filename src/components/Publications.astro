---
import { getCollection } from 'astro:content';
import { scholar } from '../data/scholar';

const publications = (await getCollection('publications')).sort((a, b) => {
  const ca = a.data.citations ?? 0;
  const cb = b.data.citations ?? 0;
  if (cb !== ca) return cb - ca; // most-cited first
  return b.data.year - a.data.year;
});
---

<section id="publications" class="section">
  <div class="container">
    <p class="eyebrow">Academic Work</p>
    <h2>Publications</h2>
    <p class="lead pubs__intro">
      Selected, most-cited work in hardware security — physical unclonable
      functions (PUFs), true random number generation, and FPGA security. Full
      list and live metrics on Google Scholar.
    </p>

    <div class="stats" role="list" aria-label="Citation metrics">
      {scholar.stats.map((s) => (
        <div class="stat" role="listitem">
          <span class="stat__value">{s.value}</span>
          <span class="stat__label">{s.label}</span>
        </div>
      ))}
    </div>

    <ol class="pubs">
      {publications.map((pub) => (
        <li class="pub">
          <div class="pub__year">{pub.data.year}</div>
          <div class="pub__detail">
            <h3 class="pub__title">{pub.data.title}</h3>
            <p class="pub__meta">
              {pub.data.authors} — <em>{pub.data.venue}</em>
            </p>
            <div class="pub__tail">
              {pub.data.citations != null && (
                <span class="pub__cites">{pub.data.citations.toLocaleString()} citations</span>
              )}
              {pub.data.type && <span class="pub__type">{pub.data.type}</span>}
              {pub.data.links.pdf && <a href={pub.data.links.pdf}>PDF</a>}
              {pub.data.links.doi && <a href={pub.data.links.doi}>DOI</a>}
              {pub.data.links.arxiv && <a href={pub.data.links.arxiv}>arXiv</a>}
            </div>
          </div>
        </li>
      ))}
    </ol>

    <a class="button pubs__all" href={scholar.profileUrl} target="_blank" rel="noopener">
      View all publications on Google Scholar →
    </a>
  </div>
</section>

<style>
  .pubs__intro {
    margin-top: 1.25rem;
  }
  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 4vw, 3rem);
    margin: 2.5rem 0 0.5rem;
    padding: 1.75rem clamp(1.25rem, 4vw, 2.5rem);
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: 12px;
  }
  .stat {
    display: flex;
    flex-direction: column;
  }
  .stat__value {
    font-family: var(--font-serif);
    font-size: var(--step-3);
    line-height: 1;
    color: var(--accent);
  }
  .stat__label {
    font-size: var(--step--1);
    color: var(--muted);
    margin-top: 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .pubs {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
  }
  .pub {
    display: grid;
    gap: 0.35rem 2rem;
    padding-block: 1.5rem;
    border-top: 1px solid var(--hairline);
  }
  @media (min-width: 700px) {
    .pub {
      grid-template-columns: 5rem 1fr;
    }
  }
  .pub__year {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    color: var(--muted);
  }
  .pub__title {
    font-size: var(--step-1);
    margin-bottom: 0.3rem;
  }
  .pub__meta {
    color: var(--ink-soft);
    margin: 0;
  }
  .pub__tail {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    margin-top: 0.6rem;
    font-size: var(--step--1);
  }
  .pub__cites {
    font-weight: 600;
    color: var(--ink);
  }
  .pub__type {
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.1em 0.6em;
    border-radius: 999px;
  }
  .pub__tail a {
    font-weight: 600;
  }
  .pubs__all {
    margin-top: 2.5rem;
  }
</style>
